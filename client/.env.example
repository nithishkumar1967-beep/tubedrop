# ============================================================
#  TubeDrop Client — Environment Variables
#  1. Copy this file: copy .env.example .env
#  2. Fill in Firebase values below
#  3. Save and run: npm run dev
# ============================================================

# Backend URL (don't change for local dev)
VITE_API_BASE_URL=http://localhost:5000/api

# ── Firebase Web Config ─────────────────────────────────────
# Get from: Firebase Console > Project Settings >
# Your Apps > (click </> Web icon) > Register app > copy config

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
# VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
