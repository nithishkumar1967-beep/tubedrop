# ============================================================
#  TubeDrop Server — Environment Variables
#  1. Copy this file: copy .env.example .env
#  2. Fill in all values below
#  3. Save and run: npm run dev
# ============================================================

NODE_ENV=development
PORT=5000

# Your frontend URL (don't change this for local dev)
ALLOWED_ORIGINS=http://localhost:5173

# ── Firebase Admin SDK ──────────────────────────────────────
# Get from: Firebase Console > Project Settings > Service Accounts
# > Generate new private key > download JSON
# Then copy the values from that JSON file here:

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-admin-sdk-email@project.iam.gserviceaccount.com
# Paste the private_key value EXACTLY from the JSON, keeping all \n characters:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Razorpay ────────────────────────────────────────────────
# Get from: dashboard.razorpay.com > Settings > API Keys
# Use TEST keys (rzp_test_...) for development

RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=YourKeySecretHere

# ── Download Settings ───────────────────────────────────────
# Windows path example: C:\Temp\tubedrop_downloads
# Linux/Mac path example: /tmp/tubedrop_downloads
TEMP_DOWNLOAD_DIR=./temp_downloads
TEMP_FILE_TTL_MINUTES=10

# ── Rate Limiting (optional) ────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# DOWNLOAD_RATE_LIMIT_MAX=10
# LOG_LEVEL=debug
